    "expo-haptics": "~14.1.4",
    "expo-linking": "~7.1.5",
    "expo-router": "~5.1.3",
    "expo-speech": "~13.1.4",
    "expo-speech-recognition": "^3.1.3",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.5.2",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "~13.15.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
